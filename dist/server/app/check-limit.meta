{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/check-limit/layout,_N_T_/check-limit/page,_N_T_/check-limit"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
