      "page": "/articles/[slug]",
      "regex": "^/articles/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/articles/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
